{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ES2015",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["@figma/plugin-typings"]
  },
  "include": ["src/plugin/**/*.ts", "src/ui/types.ts"]
}
