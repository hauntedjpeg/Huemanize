{
  "name": "huemanize",
  "version": "1.0.0",
  "description": "A Figma plugin for perceptual color interpolation",
  "scripts": {
    "build": "pnpm run build:plugin && pnpm run build:ui",
    "build:plugin": "esbuild src/plugin/code.ts --bundle --platform=node --target=es2017 --outfile=code.js --format=iife --global-name=plugin",
    "build:ui": "vite build",
    "dev": "concurrently \"pnpm run dev:plugin\" \"pnpm run dev:ui\"",
    "dev:plugin": "esbuild src/plugin/code.ts --bundle --platform=node --target=es2017 --outfile=code.js --format=iife --global-name=plugin --watch",
    "dev:ui": "vite build --watch",
    "typecheck": "tsc --noEmit -p tsconfig.plugin.json && tsc --noEmit -p tsconfig.ui.json"
  },
  "dependencies": {
    "color-name-list": "^14.36.0",
    "culori": "^4.0.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.82.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/culori": "^4.0.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.19.8",
    "stera-icons": "8.0.14",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.0.0"
  }
}
